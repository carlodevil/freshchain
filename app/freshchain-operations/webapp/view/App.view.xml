<mvc:View
  controllerName="freshchain.operations.controller.App"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns:f="sap.f"
  xmlns:core="sap.ui.core"
  xmlns="sap.m"
  displayBlock="true">
  <App id="operationsRootApp" height="100vh">
    <pages>
  <f:DynamicPage id="operationsPage" busy="{operations>/loading}" fitContent="false">
    <f:title>
      <f:DynamicPageTitle id="operationsTitle">
        <f:heading>
          <Title id="operationsHeading" text="FreshChain Operations" level="H1"/>
        </f:heading>
        <f:actions>
          <Button id="acknowledgeAlertButton" text="Acknowledge" type="Emphasized" icon="sap-icon://accept" enabled="{path: 'operations>/selectedAlertId', formatter: '.hasSelectedAlert'}" press=".onAcknowledge"/>
          <Button id="resolveAlertButton" text="Resolve" icon="sap-icon://complete" enabled="{path: 'operations>/selectedAlertId', formatter: '.hasSelectedAlert'}" press=".onResolve"/>
          <Button id="reopenAlertButton" text="Reopen" icon="sap-icon://restart" enabled="{path: 'operations>/selectedAlertId', formatter: '.hasSelectedAlert'}" press=".onReopen"/>
          <Button id="refreshOperationsButton" icon="sap-icon://refresh" tooltip="Refresh operations" press=".loadOperations"/>
        </f:actions>
      </f:DynamicPageTitle>
    </f:title>
    <f:content>
      <VBox id="operationsContent" class="sapUiMediumMargin" renderType="Bare">
        <MessageStrip id="operationsContextStrip" class="sapUiSmallMarginBottom" type="Information" showIcon="true" text="Operations cockpit for alert triage, acknowledgements, resolution, and audit history."/>

        <FlexBox id="operationsStatusBar" wrap="Wrap" alignItems="Stretch" class="sapUiTinyMarginBottom">
          <VBox id="openAlertsStatusItem" class="sapUiSmallMarginEnd sapUiSmallMarginBottom">
            <Label id="openAlertsStatusLabel" text="Open Alerts"/>
            <ObjectNumber id="openAlertsValue" number="{operations>/summary/open}" unit="alerts" state="Error"/>
            <Text id="openAlertsStatusText" text="Needs triage"/>
          </VBox>
          <VBox id="criticalAlertsStatusItem" class="sapUiSmallMarginEnd sapUiSmallMarginBottom">
            <Label id="criticalAlertsStatusLabel" text="Critical"/>
            <ObjectNumber id="criticalAlertsValue" number="{operations>/summary/critical}" unit="alerts" state="Error"/>
            <Text id="criticalAlertsStatusText" text="Highest severity"/>
          </VBox>
          <VBox id="acknowledgedAlertsStatusItem" class="sapUiSmallMarginEnd sapUiSmallMarginBottom">
            <Label id="acknowledgedAlertsStatusLabel" text="Acknowledged"/>
            <ObjectNumber id="acknowledgedAlertsValue" number="{operations>/summary/acknowledged}" unit="alerts"/>
            <Text id="acknowledgedAlertsStatusText" text="Owned work"/>
          </VBox>
          <VBox id="resolvedAlertsStatusItem" class="sapUiSmallMarginEnd sapUiSmallMarginBottom">
            <Label id="resolvedAlertsStatusLabel" text="Resolved"/>
            <ObjectNumber id="resolvedAlertsValue" number="{operations>/summary/resolved}" unit="alerts" state="Success"/>
            <Text id="resolvedAlertsStatusText" text="Closed today"/>
          </VBox>
        </FlexBox>

        <OverflowToolbar id="operationsSectionNav" class="sapUiMediumMarginTop">
          <Button id="alertsAnchor" text="Alerts" icon="sap-icon://alert" press=".onScrollToSection"><customData><core:CustomData key="target" value="alertsSection"/></customData></Button>
          <Button id="actionHistoryAnchor" text="Action History" icon="sap-icon://activity-items" press=".onScrollToSection"><customData><core:CustomData key="target" value="actionHistorySection"/></customData></Button>
        </OverflowToolbar>
        <VBox id="operationsSections" class="sapUiMediumMarginTop" renderType="Bare">
            <Panel id="alertsSection" headerText="Alerts" class="sapUiMediumMarginBottom">
              <Table id="alertsTable" mode="SingleSelectLeft" growing="true" growingThreshold="20" items="{operations>/alerts}" selectionChange=".onSelectionChange" noDataText="No alerts available. Generate demo data or run risk scoring once the backend is online.">
                <columns>
                  <Column id="alertSeverityColumn"><Text id="alertSeverityLabel" text="Severity"/></Column>
                  <Column id="alertStatusColumn"><Text id="alertStatusLabel" text="Status"/></Column>
                  <Column id="alertTypeColumn"><Text id="alertTypeLabel" text="Type"/></Column>
                  <Column id="alertTitleColumn"><Text id="alertTitleLabel" text="Alert"/></Column>
                  <Column id="alertOwnerColumn"><Text id="alertOwnerLabel" text="Owner"/></Column>
                  <Column id="alertSourceColumn"><Text id="alertSourceLabel" text="Source"/></Column>
                  <Column id="alertUpdatedColumn"><Text id="alertUpdatedLabel" text="Updated"/></Column>
                </columns>
                <items>
                  <ColumnListItem id="alertRow">
                    <cells>
                      <ObjectStatus id="alertSeverityStatus" text="{operations>severity}" state="{path: 'operations>severity', formatter: '.severityState'}"/>
                      <ObjectStatus id="alertWorkflowStatus" text="{operations>status}" state="{path: 'operations>status', formatter: '.statusState'}"/>
                      <Text id="alertTypeText" text="{operations>alertType}"/>
                      <ObjectIdentifier id="alertTitleText" title="{operations>title}" text="{operations>recommendation}"/>
                      <Text id="alertOwnerText" text="{operations>assignedTo}"/>
                      <Text id="alertSourceText" text="{operations>source}"/>
                      <Text id="alertUpdatedText" text="{operations>modifiedAt}"/>
                    </cells>
                  </ColumnListItem>
                </items>
              </Table>
            </Panel>
            <Panel id="actionHistorySection" headerText="Action History" class="sapUiMediumMarginBottom">
              <Table id="actionHistoryTable" growing="true" growingThreshold="20" items="{operations>/actions}" noDataText="No alert actions have been recorded yet.">
                <columns>
                  <Column id="actionTypeColumn"><Text id="actionTypeLabel" text="Action"/></Column>
                  <Column id="actionByColumn"><Text id="actionByLabel" text="By"/></Column>
                  <Column id="actionOwnerColumn"><Text id="actionOwnerLabel" text="Assigned To"/></Column>
                  <Column id="actionStatusColumn"><Text id="actionStatusLabel" text="Status Change"/></Column>
                  <Column id="actionCommentColumn"><Text id="actionCommentLabel" text="Comment"/></Column>
                  <Column id="actionCompletedColumn"><Text id="actionCompletedLabel" text="Completed"/></Column>
                </columns>
                <items>
                  <ColumnListItem id="actionRow">
                    <cells>
                      <ObjectStatus id="actionTypeStatus" text="{operations>actionType}" state="Information"/>
                      <Text id="actionByText" text="{operations>performedBy}"/>
                      <Text id="actionOwnerText" text="{operations>assignedTo}"/>
                      <Text id="actionStatusText" text="{operations>previousStatus} -> {operations>newStatus}"/>
                      <Text id="actionCommentText" text="{operations>comment}"/>
                      <Text id="actionCompletedText" text="{operations>completedAt}"/>
                    </cells>
                  </ColumnListItem>
                </items>
              </Table>
            </Panel>
        </VBox>
      </VBox>
    </f:content>
  </f:DynamicPage>
    </pages>
  </App>
</mvc:View>
