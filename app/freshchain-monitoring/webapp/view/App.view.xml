<mvc:View
  controllerName="freshchain.monitoring.controller.App"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:f="sap.f"
  xmlns:core="sap.ui.core"
  xmlns:layout="sap.ui.layout"
  displayBlock="true">
  <App id="monitoringRootApp" height="100vh">
    <pages>
  <f:DynamicPage id="monitoringPage" busy="{monitor>/loading}" fitContent="false">
    <f:title>
      <f:DynamicPageTitle>
        <f:heading>
          <Title id="monitoringTitle" text="FreshChain Monitoring" level="H2"/>
        </f:heading>
        <f:actions>
          <Button id="refreshMonitoringButton" icon="sap-icon://refresh" tooltip="Refresh" press=".loadMonitoring"/>
        </f:actions>
      </f:DynamicPageTitle>
    </f:title>
    <f:header>
      <f:DynamicPageHeader>
        <MessageStrip id="monitoringContext" text="Monitor zone health, active alerts, and rolling sensor aggregates from one cockpit." type="Information" showIcon="true"/>
      </f:DynamicPageHeader>
    </f:header>
    <f:content>
      <VBox id="monitoringContent" class="sapUiMediumMargin" renderType="Bare">
        <FlexBox id="monitoringStatusStrip" wrap="Wrap" alignItems="Stretch">
          <VBox id="activeZonesStatusItem" class="sapUiSmallMarginEnd sapUiSmallMarginBottom">
            <Label id="activeZonesStatusLabel" text="Active Zones"/>
            <ObjectNumber id="activeZonesStatusValue" number="{monitor>/summary/activeZones}" unit="zones" state="Success"/>
            <Text id="activeZonesStatusText" text="Monitored cold-chain estate"/>
          </VBox>
          <VBox id="activeAlertsStatusItem" class="sapUiSmallMarginEnd sapUiSmallMarginBottom">
            <Label id="activeAlertsStatusLabel" text="Active Alerts"/>
            <ObjectNumber id="activeAlertsStatusValue" number="{monitor>/summary/activeAlerts}" unit="alerts" state="Error"/>
            <Text id="activeAlertsStatusText" text="Open operational issues"/>
          </VBox>
          <VBox id="criticalAlertsStatusItem" class="sapUiSmallMarginEnd sapUiSmallMarginBottom">
            <Label id="criticalAlertsStatusLabel" text="Critical Alerts"/>
            <ObjectNumber id="criticalAlertsStatusValue" number="{monitor>/summary/criticalAlerts}" unit="critical" state="Error"/>
            <Text id="criticalAlertsStatusText" text="Immediate attention"/>
          </VBox>
          <VBox id="latestAggregateStatusItem" class="sapUiSmallMarginEnd sapUiSmallMarginBottom">
            <Label id="latestAggregateStatusLabel" text="Latest Aggregate"/>
            <ObjectNumber id="latestAggregateStatusValue" number="{monitor>/aggregates/length}"/>
            <Text id="latestAggregateStatusText" text="{monitor>/summary/latestAggregate}"/>
          </VBox>
        </FlexBox>
        <OverflowToolbar id="monitoringSectionNav" class="sapUiMediumMarginTop">
          <Button id="zoneHealthAnchor" text="Zone Health" icon="sap-icon://temperature" press=".onScrollToSection"><customData><core:CustomData key="target" value="zoneHealthSection"/></customData></Button>
          <Button id="activeAlertsAnchor" text="Active Alerts" icon="sap-icon://alert" press=".onScrollToSection"><customData><core:CustomData key="target" value="activeAlertsSection"/></customData></Button>
          <Button id="aggregatesAnchor" text="Reading Aggregates" icon="sap-icon://line-chart" press=".onScrollToSection"><customData><core:CustomData key="target" value="aggregatesSection"/></customData></Button>
        </OverflowToolbar>
        <VBox id="monitoringSections" class="sapUiMediumMarginTop" renderType="Bare">
            <Panel id="zoneHealthSection" headerText="Zone Health" class="sapUiMediumMarginBottom">
              <Table id="zoneHealthTable" items="{monitor>/zones}" growing="true">
                <columns>
                  <Column id="zoneStoreColumn"><Text text="Store"/></Column>
                  <Column id="zoneCodeColumn"><Text text="Zone"/></Column>
                  <Column id="zoneNameColumn"><Text text="Name"/></Column>
                  <Column id="zoneTypeColumn"><Text text="Type"/></Column>
                  <Column id="zoneRangeColumn"><Text text="Safe Range"/></Column>
                  <Column id="zoneActiveColumn"><Text text="Status"/></Column>
                </columns>
                <items>
                  <ColumnListItem>
                    <cells>
                      <Text text="{monitor>storeCode}"/>
                      <ObjectIdentifier title="{monitor>zoneCode}" text="{monitor>name}"/>
                      <Text text="{monitor>name}"/>
                      <Text text="{monitor>type}"/>
                      <Text text="{monitor>safeTempMinC} - {monitor>safeTempMaxC} C"/>
                      <ObjectStatus text="{= ${monitor>active} ? 'Active' : 'Inactive'}" state="{path:'monitor>active', formatter:'.activeState'}"/>
                    </cells>
                  </ColumnListItem>
                </items>
              </Table>
            </Panel>
            <Panel id="activeAlertsSection" headerText="Active Alerts" class="sapUiMediumMarginBottom">
              <Table id="activeAlertsTable" items="{monitor>/alerts}" growing="true">
                <columns>
                  <Column id="alertSeverityColumn"><Text text="Severity"/></Column>
                  <Column id="alertZoneColumn"><Text text="Zone"/></Column>
                  <Column id="alertTitleColumn"><Text text="Alert"/></Column>
                  <Column id="alertRecommendationColumn"><Text text="Recommendation"/></Column>
                  <Column id="alertAssignedColumn"><Text text="Assigned To"/></Column>
                </columns>
                <items>
                  <ColumnListItem>
                    <cells>
                      <ObjectStatus text="{monitor>severity}" state="{path:'monitor>severity', formatter:'.severityState'}"/>
                      <Text text="{monitor>zoneCode}"/>
                      <ObjectIdentifier title="{monitor>title}" text="{monitor>alertType}"/>
                      <Text text="{monitor>recommendation}"/>
                      <Text text="{monitor>assignedTo}"/>
                    </cells>
                  </ColumnListItem>
                </items>
              </Table>
            </Panel>
            <Panel id="aggregatesSection" headerText="Reading Aggregates" class="sapUiMediumMarginBottom">
              <Table id="aggregatesTable" items="{monitor>/aggregates}" growing="true">
                <columns>
                  <Column id="aggregateWindowColumn"><Text text="Window End"/></Column>
                  <Column id="aggregateZoneColumn"><Text text="Zone"/></Column>
                  <Column id="aggregateTempColumn"><Text text="Avg / Max Temp"/></Column>
                  <Column id="aggregateDoorColumn"><Text text="Door Open"/></Column>
                  <Column id="aggregateCountColumn"><Text text="Readings"/></Column>
                </columns>
                <items>
                  <ColumnListItem>
                    <cells>
                      <Text text="{monitor>windowEnd}"/>
                      <Text text="{monitor>zoneCode}"/>
                      <Text text="{monitor>tempAvg} / {monitor>tempMax} C"/>
                      <ObjectNumber number="{monitor>doorOpenSeconds}" unit="sec"/>
                      <ObjectNumber number="{monitor>readingCount}"/>
                    </cells>
                  </ColumnListItem>
                </items>
              </Table>
            </Panel>
        </VBox>
      </VBox>
    </f:content>
  </f:DynamicPage>
    </pages>
  </App>
</mvc:View>
