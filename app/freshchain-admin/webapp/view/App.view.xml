<mvc:View
  controllerName="freshchain.admin.controller.App"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:f="sap.f"
  xmlns:core="sap.ui.core"
  xmlns:layout="sap.ui.layout"
  displayBlock="true">
  <App id="adminRootApp" height="100vh">
    <pages>
  <f:DynamicPage id="adminPage" busy="{admin>/loading}" fitContent="false">
    <f:title>
      <f:DynamicPageTitle>
        <f:heading>
          <Title id="adminTitle" text="FreshChain Administration" level="H2"/>
        </f:heading>
        <f:actions>
          <Button id="replayErrorButton" text="Replay Selected Error" type="Emphasized" enabled="{path:'admin>/selectedErrorId', formatter:'.hasSelectedError'}" press=".onReplaySelectedError"/>
          <Button id="refreshAdminButton" icon="sap-icon://refresh" tooltip="Refresh" press=".loadAdmin"/>
        </f:actions>
      </f:DynamicPageTitle>
    </f:title>
    <f:header>
      <f:DynamicPageHeader>
        <MessageStrip id="adminContext" text="Administer cold-chain thresholds and inspect quarantined ingestion messages before replay." type="Information" showIcon="true"/>
      </f:DynamicPageHeader>
    </f:header>
    <f:content>
      <VBox id="adminContent" class="sapUiMediumMargin" renderType="Bare">
        <FlexBox id="adminStatusStrip" wrap="Wrap" alignItems="Stretch">
          <VBox id="thresholdsStatusItem" class="sapUiSmallMarginEnd sapUiSmallMarginBottom">
            <Label id="thresholdsStatusLabel" text="Thresholds"/>
            <ObjectNumber id="thresholdsStatusValue" number="{admin>/summary/thresholds}" unit="configs" state="Success"/>
          </VBox>
          <VBox id="openErrorsStatusItem" class="sapUiSmallMarginEnd sapUiSmallMarginBottom">
            <Label id="openErrorsStatusLabel" text="Open Errors"/>
            <ObjectNumber id="openErrorsStatusValue" number="{admin>/summary/openErrors}" unit="errors" state="Error"/>
          </VBox>
          <VBox id="quarantineStatusItem" class="sapUiSmallMarginEnd sapUiSmallMarginBottom">
            <Label id="quarantineStatusLabel" text="Quarantined Messages"/>
            <ObjectNumber id="quarantineStatusValue" number="{admin>/summary/quarantined}" unit="messages" state="Warning"/>
          </VBox>
          <VBox id="retryStatusItem" class="sapUiSmallMarginEnd sapUiSmallMarginBottom">
            <Label id="retryStatusLabel" text="Replay Attempts"/>
            <ObjectNumber id="retryStatusValue" number="{admin>/summary/retries}" unit="attempts"/>
          </VBox>
        </FlexBox>
        <OverflowToolbar id="adminSectionNav" class="sapUiMediumMarginTop">
          <Button id="thresholdsAnchor" text="Threshold Configurations" icon="sap-icon://temperature" press=".onScrollToSection"><customData><core:CustomData key="target" value="thresholdsSection"/></customData></Button>
          <Button id="ingestionErrorsAnchor" text="Ingestion Errors" icon="sap-icon://message-warning" press=".onScrollToSection"><customData><core:CustomData key="target" value="ingestionErrorsSection"/></customData></Button>
        </OverflowToolbar>
        <VBox id="adminSections" class="sapUiMediumMarginTop" renderType="Bare">
            <Panel id="thresholdsSection" headerText="Threshold Configurations" class="sapUiMediumMarginBottom">
              <Table id="thresholdsTable" items="{admin>/thresholds}" growing="true">
                <columns>
                  <Column id="thresholdZoneColumn"><Text text="Zone Type"/></Column>
                  <Column id="thresholdCategoryColumn"><Text text="Product Category"/></Column>
                  <Column id="thresholdTempColumn"><Text text="Safe Temp"/></Column>
                  <Column id="thresholdHumidityColumn"><Text text="Humidity"/></Column>
                  <Column id="thresholdDurationColumn"><Text text="Duration"/></Column>
                  <Column id="thresholdSeverityColumn"><Text text="Severity"/></Column>
                </columns>
                <items>
                  <ColumnListItem>
                    <cells>
                      <ObjectIdentifier title="{admin>zoneType}" text="{admin>productCategory}"/>
                      <Text text="{admin>productCategory}"/>
                      <Text text="{admin>safeTempMinC} - {admin>safeTempMaxC} C"/>
                      <Text text="{admin>safeHumidityMin} - {admin>safeHumidityMax} %"/>
                      <ObjectNumber number="{admin>durationMinutes}" unit="min"/>
                      <ObjectStatus text="{admin>severity}" state="{path:'admin>severity', formatter:'.severityState'}"/>
                    </cells>
                  </ColumnListItem>
                </items>
              </Table>
            </Panel>
            <Panel id="ingestionErrorsSection" headerText="Ingestion Errors" class="sapUiMediumMarginBottom">
              <Table id="ingestionErrorsTable" mode="SingleSelectLeft" selectionChange=".onErrorSelectionChange" items="{admin>/errors}" growing="true">
                <columns>
                  <Column id="errorStatusColumn"><Text text="Status"/></Column>
                  <Column id="errorClassColumn"><Text text="Class"/></Column>
                  <Column id="errorMessageColumn"><Text text="Message"/></Column>
                  <Column id="errorMessageIdColumn"><Text text="Message ID"/></Column>
                  <Column id="errorRetriesColumn"><Text text="Retries"/></Column>
                </columns>
                <items>
                  <ColumnListItem>
                    <cells>
                      <ObjectStatus text="{admin>status}" state="{path:'admin>status', formatter:'.errorState'}"/>
                      <ObjectIdentifier title="{admin>errorClass}" text="{admin>sourceQueue}"/>
                      <Text text="{admin>errorMessage}"/>
                      <Text text="{admin>messageId}"/>
                      <ObjectNumber number="{admin>retryCount}"/>
                    </cells>
                  </ColumnListItem>
                </items>
              </Table>
            </Panel>
        </VBox>
      </VBox>
    </f:content>
  </f:DynamicPage>
    </pages>
  </App>
</mvc:View>
