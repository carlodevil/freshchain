<mvc:View
  controllerName="freshchain.intelligence.controller.App"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:f="sap.f"
  xmlns:core="sap.ui.core"
  xmlns:layout="sap.ui.layout"
  xmlns:unified="sap.ui.unified"
  displayBlock="true">
  <App id="intelligenceRootApp" height="100vh">
    <pages>
  <f:DynamicPage id="intelligencePage" busy="{workbench>/loading}" fitContent="false">
    <f:title>
      <f:DynamicPageTitle>
        <f:heading>
          <Title id="intelligenceTitle" text="FreshChain Intelligence" level="H2"/>
        </f:heading>
        <f:actions>
          <Button id="startTrainingButton" text="Start AI Core Training" type="Emphasized" press=".onStartTraining"/>
          <Button id="refreshTrainingButton" icon="sap-icon://synchronize" tooltip="Refresh Training Status" press=".onRefreshLatestRun"/>
          <Button id="activateDeploymentButton" text="Activate Latest Deployment" press=".onActivateLatest"/>
          <Button id="refreshDeploymentButton" icon="sap-icon://refresh" tooltip="Refresh Deployment Status" press=".onRefreshLatestDeployment"/>
          <Button id="scoreLatestButton" text="Score Latest Zone" press=".onScoreLatest"/>
          <Button id="refreshIntelligenceButton" icon="sap-icon://refresh" tooltip="Refresh" press=".loadWorkbench"/>
        </f:actions>
      </f:DynamicPageTitle>
    </f:title>
    <f:header>
      <f:DynamicPageHeader>
        <MessageStrip id="intelligenceContext" text="Data science workbench for datasets, model runs, deployments, quality gates, and inference telemetry." type="Information" showIcon="true"/>
      </f:DynamicPageHeader>
    </f:header>
    <f:content>
      <VBox id="intelligenceContent" class="sapUiMediumMargin" renderType="Bare">
        <FlexBox id="pipelineStatusStrip" wrap="Wrap" alignItems="Stretch">
          <VBox id="datasetStatusItem" class="sapUiSmallMarginEnd sapUiSmallMarginBottom">
            <Label id="datasetStatusLabel" text="Latest Dataset"/>
            <ObjectIdentifier id="datasetStatusValue" title="{workbench>/pipeline/latestDataset}" text="{workbench>/datasets/length} datasets"/>
          </VBox>
          <VBox id="uploadStatusItem" class="sapUiSmallMarginEnd sapUiSmallMarginBottom">
            <Label id="uploadStatusLabel" text="Latest Upload"/>
            <ObjectStatus id="uploadStatusValue" text="{workbench>/pipeline/latestUpload}" state="{path:'workbench>/pipeline/latestUpload', formatter:'.stateForStatus'}" icon="sap-icon://upload"/>
            <Text id="uploadStatusText" text="{workbench>/pipeline/latestUploadName}"/>
          </VBox>
          <VBox id="trainingStatusItem" class="sapUiSmallMarginEnd sapUiSmallMarginBottom">
            <Label id="trainingStatusLabel" text="Training Run"/>
            <ObjectStatus id="trainingStatusValue" text="{workbench>/pipeline/latestRunStatus}" state="{path:'workbench>/pipeline/latestRunStatus', formatter:'.stateForStatus'}" icon="sap-icon://process"/>
            <Text id="trainingStatusText" text="{workbench>/pipeline/latestRun}"/>
          </VBox>
          <VBox id="deploymentStatusItem" class="sapUiSmallMarginEnd sapUiSmallMarginBottom">
            <Label id="deploymentStatusLabel" text="Active Deployment"/>
            <ObjectStatus id="deploymentStatusValue" text="{workbench>/pipeline/deploymentHealth}" state="{path:'workbench>/pipeline/deploymentHealth', formatter:'.stateForStatus'}" icon="sap-icon://cloud"/>
            <Text id="deploymentStatusText" text="{workbench>/pipeline/activeDeployment}"/>
          </VBox>
          <VBox id="freshnessStatusItem" class="sapUiSmallMarginEnd sapUiSmallMarginBottom">
            <Label id="freshnessStatusLabel" text="Data Freshness"/>
            <ObjectNumber id="freshnessStatusValue" number="{workbench>/dataFreshness/minutesSinceReading}" unit="min" state="{path:'workbench>/dataFreshness/health', formatter:'.stateForStatus'}"/>
            <Text id="freshnessStatusText" text="{workbench>/dataFreshness/message}"/>
          </VBox>
        </FlexBox>

        <OverflowToolbar id="intelligenceSectionNav" class="sapUiMediumMarginTop">
          <Button id="uploadsAnchor" text="Uploads" icon="sap-icon://upload" press=".onScrollToSection"><customData><core:CustomData key="target" value="uploadsSection"/></customData></Button>
          <Button id="datasetsAnchor" text="Datasets" icon="sap-icon://database" press=".onScrollToSection"><customData><core:CustomData key="target" value="datasetsSection"/></customData></Button>
          <Button id="runsAnchor" text="Training Runs" icon="sap-icon://begin" press=".onScrollToSection"><customData><core:CustomData key="target" value="runsSection"/></customData></Button>
          <Button id="deploymentsAnchor" text="Deployments" icon="sap-icon://cloud" press=".onScrollToSection"><customData><core:CustomData key="target" value="deploymentsSection"/></customData></Button>
          <Button id="qualityAnchor" text="Model Quality" icon="sap-icon://inspection" press=".onScrollToSection"><customData><core:CustomData key="target" value="qualitySection"/></customData></Button>
          <Button id="telemetryAnchor" text="Inference Telemetry" icon="sap-icon://performance" press=".onScrollToSection"><customData><core:CustomData key="target" value="telemetrySection"/></customData></Button>
        </OverflowToolbar>
        <VBox id="intelligenceSections" class="sapUiMediumMarginTop" renderType="Bare">
            <Panel id="uploadsSection" class="sapUiMediumMarginBottom">
              <headerToolbar>
                <OverflowToolbar id="uploadsToolbar">
                  <Title id="uploadsTitle" text="Dataset Uploads"/>
                  <ToolbarSpacer id="uploadsSpacer"/>
                  <Button id="downloadTemplateButton" text="Template" icon="sap-icon://download" press=".onDownloadDatasetTemplate"/>
                  <unified:FileUploader id="datasetPackageUploader" buttonOnly="true" buttonText="Upload ZIP" icon="sap-icon://upload" fileType="zip" mimeType="application/zip,application/x-zip-compressed" sameFilenameAllowed="true" change=".onDatasetPackageSelected"/>
                  <Button id="validateUploadButton" text="Validate" icon="sap-icon://validate" press=".onValidateSelectedUpload"/>
                  <Button id="importUploadButton" text="Import" type="Emphasized" icon="sap-icon://database" press=".onImportSelectedUpload"/>
                  <Button id="deleteUploadButton" icon="sap-icon://delete" tooltip="Delete Upload" press=".onDeleteSelectedUpload"/>
                </OverflowToolbar>
              </headerToolbar>
              <Table id="uploadsTable" items="{workbench>/uploads}" mode="SingleSelectLeft" selectionChange=".onDatasetUploadSelectionChange" growing="true">
                <columns>
                  <Column id="uploadFileColumn"><Text text="Package"/></Column>
                  <Column id="uploadStatusColumn"><Text text="Status"/></Column>
                  <Column id="uploadRowsColumn"><Text text="Rows"/></Column>
                  <Column id="uploadErrorsColumn"><Text text="Validation"/></Column>
                  <Column id="uploadChecksumColumn"><Text text="Checksum"/></Column>
                </columns>
                <items>
                  <ColumnListItem>
                    <cells>
                      <ObjectIdentifier title="{workbench>fileName}" text="{workbench>uploadedAt}"/>
                      <ObjectStatus text="{workbench>status}" state="{path:'workbench>status', formatter:'.stateForStatus'}"/>
                      <Text text="{workbench>rowSummary}"/>
                      <Text text="{workbench>errorSummary}"/>
                      <ObjectIdentifier title="{workbench>importedDatasetCode}" text="{workbench>checksumSha256}"/>
                    </cells>
                  </ColumnListItem>
                </items>
              </Table>
            </Panel>
            <Panel id="datasetsSection" headerText="Datasets" class="sapUiMediumMarginBottom">
              <Table id="datasetsTable" items="{workbench>/datasets}" growing="true">
                <columns>
                  <Column id="datasetCodeColumn"><Text text="Dataset"/></Column>
                  <Column id="datasetGeneratedColumn"><Text text="Generated"/></Column>
                  <Column id="datasetRowsColumn"><Text text="Rows"/></Column>
                  <Column id="datasetIncidentsColumn"><Text text="Incidents"/></Column>
                </columns>
                <items>
                  <ColumnListItem>
                    <cells>
                      <ObjectIdentifier title="{workbench>datasetCode}" text="{workbench>source}"/>
                      <Text text="{workbench>generatedAt}"/>
                      <ObjectNumber number="{workbench>readingCount}" unit="readings"/>
                      <ObjectNumber number="{workbench>incidentCount}" unit="incidents"/>
                    </cells>
                  </ColumnListItem>
                </items>
              </Table>
            </Panel>
            <Panel id="runsSection" headerText="Training Runs" class="sapUiMediumMarginBottom">
              <Table id="trainingRunsTable" items="{workbench>/trainingRuns}" growing="true">
                <columns>
                  <Column id="runIdColumn"><Text text="Run"/></Column>
                  <Column id="runModelColumn"><Text text="Model"/></Column>
                  <Column id="runStatusColumn"><Text text="Status"/></Column>
                  <Column id="runMessageColumn"><Text text="Message"/></Column>
                </columns>
                <items>
                  <ColumnListItem>
                    <cells>
                      <ObjectIdentifier title="{workbench>runId}" text="{workbench>startedAt}"/>
                      <Text text="{workbench>modelName} {workbench>modelVersion}"/>
                      <ObjectStatus text="{workbench>status}" state="{path:'workbench>status', formatter:'.stateForStatus'}"/>
                      <Text text="{workbench>errorMessage}"/>
                    </cells>
                  </ColumnListItem>
                </items>
              </Table>
            </Panel>
            <Panel id="deploymentsSection" headerText="Deployments" class="sapUiMediumMarginBottom">
              <Table id="deploymentsTable" items="{workbench>/deployments}" growing="true">
                <columns>
                  <Column id="deploymentIdColumn"><Text text="Deployment"/></Column>
                  <Column id="deploymentHealthColumn"><Text text="Health"/></Column>
                  <Column id="deploymentEndpointColumn"><Text text="Endpoint"/></Column>
                  <Column id="deploymentLastScoredColumn"><Text text="Last Scored"/></Column>
                </columns>
                <items>
                  <ColumnListItem>
                    <cells>
                      <ObjectIdentifier title="{workbench>deploymentId}" text="{workbench>modelVersion}"/>
                      <ObjectStatus text="{workbench>healthStatus}" state="{path:'workbench>healthStatus', formatter:'.stateForStatus'}"/>
                      <Text text="{workbench>endpointUrl}"/>
                      <Text text="{workbench>lastScoredAt}"/>
                    </cells>
                  </ColumnListItem>
                </items>
              </Table>
            </Panel>
            <Panel id="qualitySection" headerText="Model Quality" class="sapUiMediumMarginBottom">
              <Table id="qualityTable" items="{workbench>/modelQuality}" growing="true">
                <columns>
                  <Column id="qualityMetricColumn"><Text text="Metric"/></Column>
                  <Column id="qualityValueColumn"><Text text="Value"/></Column>
                  <Column id="qualityTargetColumn"><Text text="Target"/></Column>
                  <Column id="qualityStatusColumn"><Text text="Status"/></Column>
                </columns>
                <items>
                  <ColumnListItem>
                    <cells>
                      <Text text="{workbench>metricName}"/>
                      <ObjectNumber number="{workbench>metricValue}"/>
                      <ObjectNumber number="{workbench>targetValue}"/>
                      <ObjectStatus text="{workbench>status}" state="{path:'workbench>status', formatter:'.stateForStatus'}"/>
                    </cells>
                  </ColumnListItem>
                </items>
              </Table>
            </Panel>
            <Panel id="telemetrySection" headerText="Inference Telemetry" class="sapUiMediumMarginBottom">
              <Table id="telemetryTable" items="{workbench>/telemetry}" growing="true">
                <columns>
                  <Column id="telemetryRequestColumn"><Text text="Request"/></Column>
                  <Column id="telemetryStatusColumn"><Text text="Status"/></Column>
                  <Column id="telemetryLatencyColumn"><Text text="Latency"/></Column>
                  <Column id="telemetryAiCoreColumn"><Text text="AI Core"/></Column>
                </columns>
                <items>
                  <ColumnListItem>
                    <cells>
                      <ObjectIdentifier title="{workbench>requestId}" text="{workbench>createdAt}"/>
                      <ObjectStatus text="{workbench>status}" state="{path:'workbench>status', formatter:'.stateForStatus'}"/>
                      <ObjectNumber number="{workbench>latencyMs}" unit="ms"/>
                      <ObjectStatus text="{= ${workbench>aiCoreUnavailable} ? 'Unavailable' : 'Reached' }" state="{path:'workbench>aiCoreUnavailable', formatter:'.boolState'}"/>
                    </cells>
                  </ColumnListItem>
                </items>
              </Table>
            </Panel>
        </VBox>
      </VBox>
    </f:content>
  </f:DynamicPage>
    </pages>
  </App>
</mvc:View>
