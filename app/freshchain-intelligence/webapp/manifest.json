{
  "_version": "1.65.0",
  "sap.app": {
    "id": "freshchain.intelligence",
    "type": "application",
    "title": "FreshChain Predict",
    "description": "SAP AI Core risk decisions for live spoilage prevention",
    "applicationVersion": {
      "version": "0.1.0"
    },
    "crossNavigation": {
      "inbounds": {
        "FreshChainPredict-display": {
          "semanticObject": "FreshChainPredict",
          "action": "display",
          "title": "FreshChain Predict",
          "signature": {
            "parameters": {},
            "additionalParameters": "allowed"
          }
        }
      }
    },
    "dataSources": {
      "mainService": {
        "uri": "odata/v4/live-demo/",
        "type": "OData",
        "settings": {
          "odataVersion": "4.0"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "dependencies": {
      "minUI5Version": "1.120.0",
      "libs": {
        "sap.fe.core": {},
        "sap.fe.templates": {},
        "sap.f": {},
        "sap.m": {},
        "sap.ui.core": {}
      }
    },
    "models": {
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true,
          "synchronizationMode": "None"
        }
      },
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "uri": "i18n/i18n.properties"
      }
    },
    "routing": {
      "routes": [
        {
          "pattern": ":?query:",
          "name": "RiskDecisionsList",
          "target": "RiskDecisionsList"
        },
        {
          "pattern": "RiskDecisions({key}):?query:",
          "name": "RiskDecisionsObjectPage",
          "target": "RiskDecisionsObjectPage"
        }
      ],
      "targets": {
        "RiskDecisionsList": {
          "type": "Component",
          "id": "RiskDecisionsList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "entitySet": "RiskDecisions",
              "variantManagement": "None",
              "initialLoad": "Enabled",
              "navigation": {
                "RiskDecisions": {
                  "detail": {
                    "route": "RiskDecisionsObjectPage"
                  }
                }
              },
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "type": "ResponsiveTable",
                    "selectionMode": "Single"
                  }
                }
              }
            }
          }
        },
        "RiskDecisionsObjectPage": {
          "type": "Component",
          "id": "RiskDecisionsObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "entitySet": "RiskDecisions"
            }
          }
        }
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    }
  },
  "sap.cloud": {
    "public": true,
    "service": "freshchain"
  }
}
