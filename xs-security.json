{
  "xsappname": "freshchain",
  "tenant-mode": "dedicated",
  "oauth2-configuration": {
    "redirect-uris": [
      "https://*.cfapps.us10-001.hana.ondemand.com/**",
      "https://*.cfapps.us10.hana.ondemand.com/**",
      "https://*.cfapps.eu20-001.hana.ondemand.com/**",
      "https://*.cfapps.eu20.hana.ondemand.com/**"
    ]
  },
  "scopes": [
    {
      "name": "$XSAPPNAME.StoreStaff",
      "description": "View assigned store status and act on alerts"
    },
    {
      "name": "$XSAPPNAME.StoreManager",
      "description": "Manage store alerts and trigger evaluations"
    },
    {
      "name": "$XSAPPNAME.Admin",
      "description": "Manage FreshChain configuration and operations"
    },
    {
      "name": "$XSAPPNAME.DataScientist",
      "description": "View model and prediction data"
    },
    {
      "name": "$XSAPPNAME.IntegrationUser",
      "description": "Ingest readings and master data"
    },
    {
      "name": "$XSAPPNAME.Executive",
      "description": "View executive business impact and demo proof"
    },
    {
      "name": "$XSAPPNAME.ProcessOperator",
      "description": "Manage spoilage intervention process tasks and notifications"
    }
  ],
  "role-templates": [
    {
      "name": "StoreStaff",
      "description": "FreshChain store staff",
      "scope-references": ["$XSAPPNAME.StoreStaff"]
    },
    {
      "name": "StoreManager",
      "description": "FreshChain store manager",
      "scope-references": ["$XSAPPNAME.StoreStaff", "$XSAPPNAME.StoreManager"]
    },
    {
      "name": "Admin",
      "description": "FreshChain administrator",
      "scope-references": ["$XSAPPNAME.Admin", "$XSAPPNAME.StoreManager", "$XSAPPNAME.DataScientist"]
    },
    {
      "name": "DataScientist",
      "description": "FreshChain AI operator",
      "scope-references": ["$XSAPPNAME.DataScientist"]
    },
    {
      "name": "IntegrationUser",
      "description": "FreshChain technical ingestion user",
      "scope-references": ["$XSAPPNAME.IntegrationUser"]
    },
    {
      "name": "Executive",
      "description": "FreshChain executive viewer",
      "scope-references": ["$XSAPPNAME.Executive", "$XSAPPNAME.StoreStaff"]
    },
    {
      "name": "ProcessOperator",
      "description": "FreshChain process automation operator",
      "scope-references": ["$XSAPPNAME.ProcessOperator", "$XSAPPNAME.StoreManager"]
    }
  ]
}
