{
  "name": "freshchain",
  "version": "0.1.0",
  "private": true,
  "description": "Smart FreshChain CAP demo slice.",
  "type": "commonjs",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "start": "cds-serve",
    "watch": "cds watch",
    "deploy:local": "cds deploy --to sqlite:db.sqlite",
    "deploy:sqlite": "npm run deploy:local",
    "test": "node --test test/*.test.js",
    "check": "node --check srv/server.js && node --check srv/handlers/ingestion.js && node --check srv/handlers/rules.js && node --check srv/handlers/alert-workflow.js && node --check srv/handlers/ai-core-client.js && node --check srv/handlers/ml-engine.js && node --check srv/handlers/dataset-upload.js && node --check srv/handlers/demo-baseline.js && node --check srv/ingestion-service.js && node --check srv/catalog-service.js && node --check srv/analytics-service.js && node --check srv/admin-service.js && node --check srv/intelligence-service.js && node --check srv/live-demo-service.js && node --check simulator/src/index.js && node test/validate-ui-artifacts.js",
    "simulator": "node simulator/src/index.js",
    "build": "cds build --production",
    "build:mta": "mbt build",
    "predeploy:mta": "npm run build:mta",
    "deploy:mta": "cf deploy mta_archives/freshchain_0.1.0.mtar",
    "deploy:cf": "npm run deploy:mta"
  },
  "dependencies": {
    "@cap-js/hana": "^2.8.0",
    "@sap-ai-sdk/orchestration": "^2.11.0",
    "@sap/cds": "^9.9.1",
    "@sap/hana-client": "^2.24.24",
    "@sap/xb-msg-amqp-v100": "^0.9.58",
    "@sap/xssec": "^4.8.0",
    "express": "^4.19.2",
    "uuid": "^10.0.0",
    "yaml": "^2.5.1"
  },
  "devDependencies": {
    "@cap-js/cds-test": "^1.0.1",
    "@cap-js/sqlite": "^2.4.0",
    "@sap/cds-dk": "^9.9.2",
    "axios": "^1.7.9",
    "bestzip": "^2.2.5",
    "mbt": "^1.2.34",
    "playwright": "^1.60.0"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "sqlite",
        "credentials": {
          "url": "db.sqlite"
        }
      },
      "auth": {
        "kind": "mocked"
      },
      "messaging": {
        "[development]": {
          "kind": "local-messaging"
        },
        "[test]": {
          "kind": "local-messaging"
        },
        "[production]": {
          "kind": "enterprise-messaging-shared"
        }
      },
      "[production]": {
        "db": {
          "kind": "hana",
          "pool": {
            "acquireTimeoutMillis": 10000,
            "max": 10,
            "min": 0
          }
        },
        "auth": {
          "kind": "xsuaa"
        }
      }
    },
    "odata": {
      "version": "v4"
    },
    "features": {
      "assert_integrity": false
    }
  }
}
